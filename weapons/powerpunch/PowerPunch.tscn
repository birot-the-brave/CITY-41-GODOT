[sub_resource type="GDScript" id="GDScript_ia6d5"]
script/source = "extends \"res://scripts/weapons/GunBase.gd\"

# Power Punch – melee weapon with automatic recharge (cooldown)
# Inherits from GunBase to get fire_rate, ammo handling, etc.

@export var punch_range: float = 2.0          # Reach of the punch
@export var screen_shake_amount: float = 0    # Camera shake magnitude on hit
@export var screen_shake_time: float = 0.12   # Duration of shake

var _ready_to_punch: bool = true
var _shake_timer: float = 0.0
var _original_camera_transform: Transform3D
var _cooldown_timer: float = 0.0   # internal cooldown timer

func _ready() -> void:
	# Cache camera transform for shake reset
	var cam: Camera3D = get_viewport().get_camera_3d()
	if cam:
		_original_camera_transform = cam.global_transform
	else:
		push_warning("PowerPunch: No Camera3D found – screen shake disabled.")

	# Reset cooldown
	_cooldown_timer = 0.0
	# If we start with no ammo (magazine == 0), impose cooldown before first shot
	if magazine == 0:
		_cooldown_timer = stats.get("fire_rate", 0.6)

func _process(delta: float) -> void:
	# Reset camera shake
	if _shake_timer > 0.0:
		_shake_timer -= delta
		if _shake_timer <= 0.0 and is_instance_valid(get_viewport().get_camera_3d()):
			get_viewport().get_camera_3d().global_transform = _original_camera_transform

	# Update cooldown timer
	if _cooldown_timer > 0.0:
		_cooldown_timer = max(0.0, _cooldown_timer - delta)
		# When cooldown finishes, reset magazine to 1 (ready state)
		if _cooldown_timer <= 0.0:
			magazine = 1
			ammo_changed.emit(magazine, reserve)

func _physics_process(_delta: float) -> void:
	# We replicate GunBase's _physics_process but with our own cooldown logic
	# (GunBase also handles reloading; we disable reload for this weapon)

	var cam: Camera3D = get_viewport().get_camera_3d()
	if not cam:
		return

	# Determine if we want to fire based on automatic mode
	var wants_to_fire: bool
	if stats.get("automatic", false):
		wants_to_fire = Input.is_action_pressed("Fire")
	else:
		wants_to_fire = Input.is_action_just_pressed("Fire")

	# Fire if cooldown ready and we want to fire
	if wants_to_fire and _cooldown_timer <= 0.0:
		# Consume ammo (set magazine to 0) to show cooldown visually
		magazine = 0
		ammo_changed.emit(magazine, reserve)
		# Start cooldown
		_cooldown_timer = stats.get("fire_rate", 0.6)  # use fire_rate from stats as cooldown
		_perform_shot()

	# Ignore reload input (weapon has no ammo/reload)
	if Input.is_action_just_pressed("Reload"):
		# Optionally play a dry click sound or just ignore
		pass

func _perform_shot() -> void:
	# --- Screen shake on hit (optional) ---
	var cam: Camera3D = get_viewport().get_camera_3d()
	if cam:
		var start_xf: Transform3D = cam.global_transform
		var offset: Vector3 = Vector3(
			randf() * 2.0 - 1.0,
			randf() * 2.0 - 1.0,
			randf() * 2.0 - 1.0
		) * screen_shake_amount
		cam.global_transform.origin += offset
		_shake_timer = screen_shake_time
		_original_camera_transform = start_xf

	# --- Melee raycast ---
	var from: Vector3
	var forward: Vector3
	if cam:
		from = cam.global_position
		forward = -cam.global_transform.basis.z
	else:
		from = Vector3.ZERO
		forward = Vector3.FORWARD

	var to: Vector3 = from + forward * punch_range

	var query: PhysicsRayQueryParameters3D = PhysicsRayQueryParameters3D.create(from, to)
	var result: Dictionary = get_world_3d().direct_space_state.intersect_ray(query)

	if result.has("collider"):
		var collider: Object = result["collider"]
		if collider.has_method("take_damage"):
			# Determine headshot vs body (simple flag, replace with your hitbox logic)
			var is_headshot: bool = collider.has_method("is_head") and collider.is_head()
			var base_damage: int = stats.get("head_dmg", 0) if is_headshot else stats.get("body_dmg", 0)
			var variance: int = stats.get("damage_variance", 0)
			var final_damage: int = base_damage + randi_range(-variance, variance)
			final_damage = maxi(1, final_damage)  # ensure at least 1 damage
			collider.take_damage(final_damage)

			# OPTIONAL: spawn hit VFX / play sound here
			# e.g., $HitParticles.emit()

	# Let GunBase handle save_state (we already call save_state via _physics_process? Actually we bypass GunBase._fire)
	# We'll call save_state here to persist ammo state.
	save_state()

	# Note: _ready_to_punch flag is not used; we rely on _cooldown_timer
	# Keeping the variable for potential future use or compatibility.
	_ready_to_punch = true

# Override to disable reload (weapon uses cooldown, not ammo)
func _reload() -> void:
	# Do nothing; this weapon recharges automatically over time
	pass
"

